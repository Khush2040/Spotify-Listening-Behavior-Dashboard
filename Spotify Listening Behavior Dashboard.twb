    <worksheet name='Sheet 5'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book'>Top Songs + Skip Behavior</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='spotify_history' name='federated.00wvpki0xyxd4c16khysf1jo6rgx' />
          </datasources>
          <datasource-dependencies datasource='federated.00wvpki0xyxd4c16khysf1jo6rgx'>
            <column caption='Skip Flag' datatype='string' name='[Calculation_0624311684653061]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [reason_end] = &quot;fwdbtn&quot; OR [reason_end] = &quot;backbtn&quot;&#13;&#10;THEN &quot;Skipped&quot;&#13;&#10;ELSE &quot;Played&quot;&#13;&#10;END' />
            </column>
            <column caption='Skip Rate' datatype='real' name='[Calculation_0624311689875465]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_0624311684653061]=&quot;Skipped&quot; THEN 1 END)&#13;&#10;/ COUNT([track_name])' />
            </column>
            <column-instance column='[track_name]' derivation='Count' name='[cnt:track_name:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_0624311684653061]' derivation='None' name='[none:Calculation_0624311684653061:nk]' pivot='key' type='nominal' />
            <column-instance column='[track_name]' derivation='None' name='[none:track_name:nk]' pivot='key' type='nominal' />
            <column caption='Reason End' datatype='string' name='[reason_end]' role='dimension' type='nominal' />
            <column caption='Track Name' datatype='string' name='[track_name]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_0624311689875465]' derivation='User' name='[usr:Calculation_0624311689875465:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='on' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <size column='[federated.00wvpki0xyxd4c16khysf1jo6rgx].[cnt:track_name:qk]' />
              <color column='[federated.00wvpki0xyxd4c16khysf1jo6rgx].[usr:Calculation_0624311689875465:qk]' />
              <text column='[federated.00wvpki0xyxd4c16khysf1jo6rgx].[none:Calculation_0624311684653061:nk]' />
              <text column='[federated.00wvpki0xyxd4c16khysf1jo6rgx].[none:track_name:nk]' />
            </encodings>
            <style>
