      <aliases enabled='yes' />
      <column caption='Year' datatype='integer' name='[Calculation_0624311684104192]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([ts])' />
      </column>
      <column caption='Month' datatype='string' name='[Calculation_0624311684272129]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [ts])' />
      </column>
      <column caption='Hour' datatype='integer' name='[Calculation_0624311684382723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, [ts])' />
      </column>
      <column caption='Time of Day' datatype='string' name='[Calculation_0624311684595716]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0624311684382723] &lt; 6 THEN &quot;Late Night&quot;&#13;&#10;ELSEIF [Calculation_0624311684382723] &lt; 12 THEN &quot;Morning&quot;&#13;&#10;ELSEIF [Calculation_0624311684382723] &lt; 18 THEN &quot;Afternoon&quot;&#13;&#10;ELSE &quot;Evening&quot;&#13;&#10;END' />
      </column>
      <column caption='Skip Flag' datatype='string' name='[Calculation_0624311684653061]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [reason_end] = &quot;fwdbtn&quot; OR [reason_end] = &quot;backbtn&quot;&#13;&#10;THEN &quot;Skipped&quot;&#13;&#10;ELSE &quot;Played&quot;&#13;&#10;END' />
      </column>
      <column caption='New vs Repeat Artist' datatype='string' name='[Calculation_0624311684894727]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [artist_name] : MIN([ts]) } = [ts]&#13;&#10;THEN &quot;New Artist&quot;&#13;&#10;ELSE &quot;Repeat Artist&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Streams' datatype='integer' name='[Calculation_0624311684997128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([track_name])' />
      </column>
      <column caption='Skip Rate' datatype='real' name='[Calculation_0624311689875465]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_0624311684653061]=&quot;Skipped&quot; THEN 1 END)&#13;&#10;/ COUNT([track_name])' />
      </column>
